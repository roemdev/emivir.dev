---
import Icon from './Icon.astro';

const projects = [
  {
    title: 'Iglesia CCER',
    desc: 'Plataforma enfocada en la comunicación de eventos y visión institucional.',
    icon: 'church',
    url: 'https://ccer-web.vercel.app'
  },
  {
    title: 'Salud Dr. Arvelo',
    desc: 'Landing page profesional con sistema directo para agendamiento de citas.',
    icon: 'stethoscope',
    url: '#'
  },
  {
    title: 'Firma Legal García',
    desc: 'Presencia digital sobria para firma legal, priorizando autoridad y confianza.',
    icon: 'gavel',
    url: '#'
  }
];
---
<section id="proyectos" class="max-w-6xl mx-auto px-6 pt-14 pb-12 md:pt-20 md:pb-20">
  <div class="mb-12">
    <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand">Portafolio</p>
    <h2 class="mt-3 text-4xl md:text-5xl font-black tracking-tight">Casos diseñados para generar credibilidad.</h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {projects.map(project => (
      <a href={project.url} target="_blank" rel="noopener noreferrer" class="group block">
        <article class="h-full rounded-[1.75rem] border border-slate-200 bg-white p-6 transition-all duration-300 hover:-translate-y-1 hover:border-brand/40 hover:shadow-xl hover:shadow-slate-200/50 dark:border-slate-800 dark:bg-slate-900 dark:hover:shadow-none">
          <div class="mb-6 flex aspect-video items-center justify-center rounded-2xl border border-slate-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-800/80">
            <Icon name={project.icon} class="project-icon w-12 h-12 text-slate-300 transition-all duration-300 dark:text-slate-600 group-hover:text-brand" />
          </div>
          <h3 class="text-xl font-extrabold tracking-tight">{project.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-300">{project.desc}</p>
        </article>
      </a>
    ))}
  </div>
</section>
