---
import Icon from './Icon.astro';
import { solutions } from './solutionsData';
---
<section id="soluciones" class="max-w-6xl mx-auto px-6 py-20 md:py-24">
  <div class="mb-12 md:mb-14 text-center md:text-left">
    <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand">Servicios</p>
    <h2 class="mt-3 text-4xl md:text-5xl font-black tracking-tight">Soluciones orientadas a confianza y resultados.</h2>
    <p class="mt-5 text-slate-600 dark:text-slate-300 max-w-3xl">
      Cada propuesta combina posicionamiento, diseño visual y estructura de contenido para ayudarte a cerrar más oportunidades con una presencia digital coherente.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-7">
    {solutions.map(item => (
      <article class="group relative overflow-hidden rounded-[2rem] border border-slate-200/90 bg-white p-8 md:p-10 transition-all duration-300 hover:-translate-y-1 hover:border-brand/40 hover:shadow-xl hover:shadow-slate-200/50 dark:border-slate-800 dark:bg-slate-900 dark:hover:shadow-none">
        <div class="absolute -right-12 -top-12 h-40 w-40 rounded-full bg-brand/10 blur-2xl transition group-hover:bg-brand/20"></div>
        <div class="relative">
          <div class="mb-7 inline-flex rounded-xl border border-brand/20 bg-brand/10 p-3 text-brand dark:border-brand/30 dark:bg-brand/15">
            <Icon name={item.icon} class="w-7 h-7" />
          </div>
          <h3 class="text-2xl font-black tracking-tight">{item.title}</h3>
          <p class="mt-4 text-base text-slate-600 dark:text-slate-300 leading-relaxed">{item.description}</p>
        </div>
      </article>
    ))}
  </div>
</section>
