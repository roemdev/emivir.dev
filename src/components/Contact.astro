---
import Icon from './Icon.astro';
---
<section id="contacto" class="max-w-6xl mx-auto px-6 pb-28 pt-8">
  <div class="relative overflow-hidden rounded-[2.5rem] border border-slate-200 bg-gradient-to-br from-white via-slate-50 to-sky-50 p-10 md:p-16 dark:border-slate-800 dark:from-slate-900 dark:via-slate-900 dark:to-slate-800">
    <div class="absolute -right-16 top-0 h-60 w-60 rounded-full bg-brand/20 blur-3xl dark:bg-brand/25"></div>
    <div class="absolute -left-16 bottom-0 h-52 w-52 rounded-full bg-indigo-400/20 blur-3xl dark:bg-indigo-500/20"></div>

    <div class="relative z-10 grid items-center gap-10 lg:grid-cols-2">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand">Siguiente paso</p>
        <h2 class="mt-4 text-4xl md:text-6xl font-black tracking-tight leading-[0.95] text-balance">
          ¿Listo para que tu web se vea al nivel de tu trabajo?
        </h2>
      </div>

      <div class="space-y-6 text-left">
        <p class="text-lg text-slate-700 dark:text-slate-200 leading-relaxed">
          Cuéntame qué necesitas y te propondré una ruta clara para elevar tu presencia digital con una imagen seria, moderna y convincente.
        </p>

        <div class="flex flex-col sm:flex-row sm:items-center gap-4">
          <a href="mailto:hola@emivir.dev" class="inline-flex items-center justify-center gap-3 rounded-2xl bg-slate-900 px-7 py-4 text-base font-bold text-white transition hover:bg-brand dark:bg-white dark:text-slate-900 dark:hover:bg-brand dark:hover:text-white">
            <Icon name="mail" class="h-5 w-5" />
            hola@emivir.dev
          </a>
          <a href="https://api.whatsapp.com/send?phone=18293204611" class="inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-300 px-6 py-4 text-sm font-bold text-slate-700 transition hover:border-brand hover:text-brand dark:border-slate-700 dark:text-slate-200">
            <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 fill-current">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            WhatsApp directo
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
