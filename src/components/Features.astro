---
const features = [
  {
    number: '01',
    title: 'Dirección clara',
    description: 'Definimos una narrativa visual y verbal que proyecta autoridad, sin perder cercanía.'
  },
  {
    number: '02',
    title: 'Velocidad premium',
    description: 'Arquitectura liviana, excelente rendimiento y una experiencia fluida en cualquier dispositivo.'
  },
  {
    number: '03',
    title: 'Confianza medible',
    description: 'Estructuras pensadas para que tus visitantes entiendan rápido qué haces y por qué elegirte.'
  }
];
---

<section id="sobre-mi" class="max-w-6xl mx-auto px-6 py-16 md:py-20">
  <div class="rounded-[2.25rem] border border-slate-200/90 bg-white/85 p-8 md:p-12 shadow-lg shadow-slate-200/40 dark:border-slate-800 dark:bg-slate-900/70 dark:shadow-none">
    <div class="grid gap-12 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand">Enfoque UX/UI profesional</p>
        <h2 class="mt-4 text-4xl md:text-5xl font-black tracking-tight text-balance">
          Diseño sobrio, estratégico y memorable.
        </h2>
        <p class="mt-6 text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
          No creo webs “bonitas” por estética. Diseño experiencias digitales orientadas a reputación, claridad y decisión: para que el usuario perciba calidad desde el primer scroll.
        </p>
      </div>

      <div class="lg:col-span-5 grid gap-4">
        {features.map((item) => (
          <article class="rounded-2xl border border-slate-200 bg-slate-50/90 p-5 dark:border-slate-700 dark:bg-slate-800/70">
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand">{item.number}</p>
            <h3 class="mt-2 text-lg font-extrabold">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
